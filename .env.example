# =============================================================================
# Sportsbook Affiliate Bot — example environment.
# Copy to ".env" and fill in real values. ".env" is gitignored.
# =============================================================================

# --- Core (REQUIRED) ---------------------------------------------------------
# Telegram Bot API token from @BotFather.
BOT_TOKEN=000000000:replace-with-your-bot-token
# Admin chat/user id (numeric) that receives alerts & escalations.
ADMIN_CHAT_ID=100000000
# External offer landing URL the bot routes users to.
LANDING_URL=https://your-affiliate-offer.example.com/landing
# Bot username (without @) for referral deep links: https://t.me/<username>?start=<code>
BOT_USERNAME=your_bot_username

# --- Database ----------------------------------------------------------------
# SQLite (MVP). For Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# --- Runtime -----------------------------------------------------------------
ENVIRONMENT=dev            # dev | prod
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
DEFAULT_LANG=en            # en | ru

# --- Payments (OPTIONAL; leave disabled for MVP) -----------------------------
PAYMENTS_ENABLED=false
XROCKET_API_KEY=
XROCKET_BASE_URL=https://pay.xrocket.tg/
XROCKET_MODE=testnet       # testnet | live

# --- Webhook (OPTIONAL; long polling is the default) -------------------------
# Enable only if an external provider requires HTTPS callbacks.
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=
WEBHOOK_BASE_URL=
